# =============================================================================
# PCS Vector — Streamlit secrets template
# =============================================================================
#
# LOCAL:  cp .streamlit/secrets.toml.example .streamlit/secrets.toml
# CLOUD:  Streamlit Cloud → App → Settings → Secrets (paste TOML below)
#
# Never commit secrets.toml to git.
# =============================================================================

[stripe]
publishable_key = "pk_test_YOUR_PUBLISHABLE_KEY"
secret_key = "sk_test_YOUR_SECRET_KEY"

[grok]
api_key = "xai-YOUR_GROK_API_KEY"

[pcs_vector]
# REQUIRED after deploying to Streamlit Cloud — use your live app URL exactly:
# https://your-app-name.streamlit.app
app_url = "http://localhost:8501"